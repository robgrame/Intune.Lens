{
  "manifest_version": 3,
  "name": "Intune Lens",
  "version": "2.7.1",
  "description": "Rich hover cards for Microsoft Intune objects — see device details, user info, compliance status, and more at a glance.",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://intune.microsoft.com/*",
    "https://graph.microsoft.com/*",
    "https://hosting.portal.azure.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://intune.microsoft.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://intune.microsoft.com/*",
        "https://*.hosting.portal.azure.net/*",
        "https://hosting.portal.azure.net/*",
        "https://*.portal.azure.net/*",
        "https://*.portal.azure.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Intune Lens"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
